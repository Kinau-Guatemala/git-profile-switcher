{
  "name": "git-config-switcher",
  "version": "1.0.0",
  "description": "Cross-platform desktop tray app for managing multiple Git identities",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --win --config.win.sign=null",
    "build:arch": "tsc && vite build && electron-builder --linux pacman",
    "build:appimage": "tsc && vite build && electron-builder --linux AppImage",
    "preview": "vite preview",
    "test": "vitest"
  },
  "keywords": ["electron", "git", "config", "switcher"],
  "author": "Jose Andres Auyon <auyon.joseandres@gmail.com>",
  "homepage": "https://github.com/auyjos/GithubProfileSwitcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/auyjos/GithubProfileSwitcher.git"
  },
  "license": "MIT",
  "build": {
    "appId": "com.gitconfigswitcher.app",
    "productName": "Git Config Switcher",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage",
      "maintainer": "Jose Andres Auyon <auyon.joseandres@gmail.com>"
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vite-plugin-electron": "^0.28.1",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "execa": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  }
}
